# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=aastu_events
DB_USER=root
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Google OAuth (optional — leave blank to disable Google login)
# Get credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Explicit redirect URI to register in Google Cloud Console for production (e.g. https://aastu-event-hub.onrender.com/api/auth/google/callback)
GOOGLE_REDIRECT_URI=
# Backend base URL (used as fallback for local development)
BACKEND_URL=http://localhost:5000

# GitHub OAuth (optional — leave blank to disable GitHub login)
# If you add GitHub OAuth, register the callback URL in your GitHub OAuth App settings
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=
